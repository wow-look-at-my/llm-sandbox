{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./src/*"],
      "@opencode-ai/ui/*": ["./src/ui/*"],
      "@opencode-ai/core/util/*": ["./src/lib/utils/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
